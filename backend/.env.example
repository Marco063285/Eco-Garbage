# ================================
# ECO-GARBAGE BACKEND — VARIABLES D'ENVIRONNEMENT
# Copiez ce fichier en .env et remplissez les valeurs
# ================================

# Serveur
PORT=5000
NODE_ENV=development

# Base de données MongoDB
MONGO_URI=mongodb+srv://youruser:yourpassword@cluster0.xxxxx.mongodb.net/eco_garbage_db

# JWT
JWT_SECRET=votre_secret_jwt_ultra_securise_changez_moi
JWT_EXPIRES_IN=7d

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# Upload fichiers
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
