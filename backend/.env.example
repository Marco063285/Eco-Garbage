# ============================================================
# EcoGarbage backend — example environment file
# Copy to .env (for local) or set as environment variables on Render
# ============================================================

# Server
PORT=5000
NODE_ENV=production

# MongoDB (use MongoDB Atlas connection string in production)
# Example: mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/eco_garbage_db?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/eco_garbage_db

# JWT - generate a strong random value, e.g.
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Frontend URL (CORS) — comma-separated list of allowed origins
# Production example: https://eco-garbage-frontend.onrender.com
FRONTEND_URL=http://localhost:5173

# Upload fichiers
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# ---- Email (optional, required for email verification + password reset) ----
# Recommended: a transactional SMTP provider (Brevo, Mailgun, Resend, Gmail App Password, etc.)
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=
MAIL_PASS=
MAIL_FROM=no-reply@ecogarbage.app
