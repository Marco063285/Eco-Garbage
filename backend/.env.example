# ================================
# ECO-GARBAGE BACKEND — Environment variables
# Copy this file to .env (local) or set them in the Render dashboard (production).
# ================================

# ─── Server ───────────────────────────────────────
# Render injects PORT automatically — leave blank in production.
PORT=5000
NODE_ENV=production

# ─── MongoDB Atlas ────────────────────────────────
# Free cluster: https://www.mongodb.com/cloud/atlas
# Replace <user>, <password>, <cluster> with your values. Keep /eco_garbage_db.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/eco_garbage_db?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────
# Generate a strong secret: `openssl rand -hex 64` (or any 64+ char random string)
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d

# ─── Frontend / CORS ──────────────────────────────
# Comma-separated list of allowed origins (no trailing slash).
# Any *.vercel.app preview is also allowed automatically by server.js.
FRONTEND_URL=https://your-app.vercel.app

# ─── Email (nodemailer) ───────────────────────────
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=
MAIL_PASS=
MAIL_FROM=no-reply@ecogarbage.app

# ─── Uploads ──────────────────────────────────────
# NOTE: Render's free disk is EPHEMERAL — files written to ./uploads disappear
# on every redeploy/restart. For persistent file storage in production, swap
# multer disk storage for Cloudinary / S3 / Render Disks (paid).
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
