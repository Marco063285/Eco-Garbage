# ================================
# ECO-GARBAGE BACKEND — Environment variables
# Copy this file to .env (local) or set them in the Render dashboard (production).
# ================================

# ─── Server ───────────────────────────────────────
# Render injects PORT automatically — leave blank in production.
PORT=5000
NODE_ENV=production

# ─── MongoDB Atlas ────────────────────────────────
# Free cluster: https://www.mongodb.com/cloud/atlas
# Replace <user>, <password>, <cluster> with your values. Keep /eco_garbage_db.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/eco_garbage_db?retryWrites=true&w=majority
MONGO_MAX_POOL_SIZE=20
MONGO_MIN_POOL_SIZE=2
# Manual maintenance only. Keep false during normal startup.
MONGO_DROP_OBSOLETE_INDEXES=false

# ─── JWT ──────────────────────────────────────────
# Generate a strong secret: `openssl rand -hex 64` (or any 64+ char random string)
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d
DATA_ENCRYPTION_KEY=replace_me_with_another_long_random_string
# Mandatory in production. Existing administrators enroll at their next login.
ADMIN_2FA_REQUIRED=true
# During key rotation, keep old keys here until all files are re-encrypted.
# Multiple keys are comma-separated.
DATA_ENCRYPTION_KEY_PREVIOUS=

# ─── Frontend / CORS ──────────────────────────────
# Comma-separated list of allowed origins (no trailing slash).
# Any *.vercel.app preview is also allowed automatically by server.js.
FRONTEND_URL=https://your-app.vercel.app

# ─── Email (nodemailer) ───────────────────────────
# Option A — SendGrid (recommended, free 100 emails/day)
#   1. Create account at sendgrid.com → Settings → API Keys → Mail Send
#   MAIL_HOST=smtp.sendgrid.net  MAIL_PORT=587  MAIL_USER=apikey  MAIL_PASS=SG.xxx
#
# Option B — Gmail (App Password required — Security → 2-Step → App passwords)
#   MAIL_HOST=smtp.gmail.com  MAIL_PORT=465  MAIL_USER=you@gmail.com  MAIL_PASS=xxxx
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=
MAIL_PASS=
MAIL_FROM=no-reply@ecogarbage.app

# ─── Cloudinary (persistent file storage) ─────────
# Required on Render free plan — local disk is ephemeral.
# 1. Create free account at cloudinary.com
# 2. Dashboard → API Keys → copy the "API environment variable" (cloudinary://...)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ─── Uploads ──────────────────────────────────────
UPLOAD_DIR=src/private_uploads
MAX_FILE_SIZE=5242880
PICKUP_PROOF_DIR=src/private_uploads/pickup-proofs

# Sensitive document retention and background maintenance
# Approved collector identity files: 2 years by default.
APPROVED_COLLECTOR_DOCUMENT_RETENTION_DAYS=730
# Rejected applications: 90 days by default.
REJECTED_COLLECTOR_DOCUMENT_RETENTION_DAYS=90
# Before/after pickup proofs: 1 year by default.
PICKUP_PROOF_RETENTION_DAYS=365
COMPLAINT_EVIDENCE_RETENTION_DAYS=365
SENSITIVE_DATA_CLEANUP_INTERVAL_HOURS=6
SENSITIVE_FILE_MIGRATION_BATCH_SIZE=100

# Collector wallet
PLATFORM_COMMISSION_RATE=15

# Payment webhooks
# Generate with: openssl rand -hex 64
# The provider must sign: HMAC-SHA256(secret, "<unix_timestamp>.<raw_json_body>")
PAYMENT_WEBHOOK_SECRET=replace_me_with_a_long_random_payment_webhook_secret

# Firebase Cloud Messaging (use one format only)
# Base64-encode the complete Firebase service-account JSON for Render.
FIREBASE_SERVICE_ACCOUNT_BASE64=
# Local alternative. Keep the JSON on one line.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Reliable notification delivery
NOTIFICATION_MAX_ATTEMPTS=4
NOTIFICATION_RETRY_INTERVAL_SECONDS=30

# Performance monitoring and abusive request protection
# Production records 10% of normal/client-error requests plus every 5xx/slow request.
MONITORING_METRIC_SAMPLE_RATE=0.1
MONITORING_SLOW_REQUEST_MS=1500
API_RATE_LIMIT_PER_MINUTE=600
AUTH_RATE_LIMIT_PER_15_MINUTES=15
GPS_RATE_LIMIT_PER_MINUTE=120
CHAT_WRITE_RATE_LIMIT_PER_MINUTE=30
CHAT_READ_RATE_LIMIT_PER_MINUTE=120
NOTIFICATION_RATE_LIMIT_PER_MINUTE=120
REQUEST_READ_RATE_LIMIT_PER_MINUTE=180
EXPENSIVE_OPERATION_RATE_LIMIT_PER_MINUTE=30
WEBHOOK_RATE_LIMIT_PER_MINUTE=180
SOCKET_CONNECTION_RATE_LIMIT_PER_MINUTE=30
SOCKET_JOIN_RATE_LIMIT_PER_MINUTE=20

# MongoDB encrypted backups
# Requires official MongoDB Database Tools: mongodump and mongorestore.
BACKUP_ENABLED=false
BACKUP_DIR=backups
BACKUP_ENCRYPTION_KEY=replace_me_with_a_distinct_32_char_minimum_secret
BACKUP_DAILY_HOUR_UTC=2
BACKUP_RETENTION_DAYS=30
BACKUP_RETENTION_COUNT=14
# Optional explicit executable paths on Windows or custom containers.
MONGODUMP_PATH=
MONGORESTORE_PATH=
# Never enable this permanently. It only unlocks an explicitly requested
# restore onto the source database.
ALLOW_PRODUCTION_RESTORE=false
