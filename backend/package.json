{
  "name": "eco-garbage-backend",
  "version": "1.0.0",
  "description": "API REST pour la plateforme Eco-Garbage",
  "main": "src/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "start:production": "node scripts/startProduction.js",
    "dev": "nodemon src/server.js",
    "db:init": "node src/config/initDb.js",
    "security:maintain": "node scripts/maintainSensitiveData.js",
    "verification:maintain": "node scripts/maintainCollectorVerification.js",
    "backup:create": "node scripts/backupMongo.js",
    "backup:restore": "node scripts/restoreMongo.js",
    "backup:test-restore": "node scripts/testMongoRestore.js",
    "db:indexes": "node scripts/ensureMongoIndexes.js",
    "db:backfill-collector-photos": "node scripts/backfillCollectorProfilePhotos.js",
    "perf:load": "node scripts/loadTest.js",
    "perf:mongo": "node scripts/mongoPerformanceAudit.js",
    "test": "node --test test/*.test.js",
    "test:workflow": "node --test test/completeWorkflow.test.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.5",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
