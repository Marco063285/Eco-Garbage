# This file is committed and used during `vite build` on Render.
# Replace the URL below with your actual Render backend URL AFTER you've created the backend service.
# Leaving it empty makes the built app call its own origin's /api (which only works if you serve
# backend and frontend from the same domain). For Render (separate services), set this explicitly.
VITE_API_URL=https://eco-garbage-backend.onrender.com
