# EcoGarbage frontend — environment variables
# Copy to .env.local for local dev, or set on Render for production.

# Base URL of the deployed backend (no trailing slash).
# - In local dev, leave it BLANK so Vite proxies /api to localhost:5000.
# - In production set it to your Render backend URL.
# Example: https://eco-garbage-backend.onrender.com
VITE_API_URL=
